{
  "name": "@edmolima/arbitro",
  "version": "0.2.0",
  "description": "Deterministic model router — picks the best OpenRouter model for a prompt before you call it.",
  "license": "MIT",
  "author": "Edmo Lima <edmo.lima@afparcapital.com>",
  "keywords": [
    "openrouter",
    "llm",
    "model-router",
    "routing",
    "ai",
    "deterministic",
    "cost-optimization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edmolima/arbitro.git",
    "directory": "packages/arbitro"
  },
  "homepage": "https://github.com/edmolima/arbitro#readme",
  "bugs": {
    "url": "https://github.com/edmolima/arbitro/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
